# Research OS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://research_os:DB_PASSWORD_REDACTED@localhost:5432/research_os
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://:REDIS_PASSWORD_REDACTED@localhost:6379/0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ============================================
# File Storage Configuration
# ============================================
# Local file storage on /data disk
STORAGE_BACKEND=local
STORAGE_BASE_PATH=/data/research-os/files
PDF_STORAGE_PATH=/data/research-os/pdfs
CACHE_PATH=/data/research-os/cache
LOG_PATH=/data/research-os/logs

# ============================================
# LLM Configuration
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_DEFAULT=gpt-4o
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Tongyi/DashScope Embedding & Rerank
# ============================================
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024
DASHSCOPE_MULTIMODAL_MODEL=qwen3-vl-embedding
DASHSCOPE_RERANK_MODEL=gte-rerank-v2

# ============================================
# Academic Data Sources
# ============================================
SEMANTIC_SCHOLAR_API_KEY=your-s2-api-key-here
OPENALEX_EMAIL=your-email@example.com
UNPAYWALL_EMAIL=your-email@example.com

# ============================================
# GROBID Configuration
# ============================================
GROBID_URL=http://localhost:8070

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=false

# ============================================
# Observability
# ============================================
LOG_LEVEL=INFO
ENABLE_TRACING=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ============================================
# Research Run Defaults
# ============================================
DEFAULT_MAX_RUNTIME_MINUTES=90
DEFAULT_MAX_PAPERS=150
DEFAULT_MAX_FULLTEXT_READS=40
DEFAULT_MAX_COST_USD=30.0
